{
  "name": "sprouter-native-qr-image-reader",
  "version": "1.0.4",
  "description": "sample",
  "main": "lib/module/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index.tsx",
  "codegenConfig": {
    "name": "SprouterNativeQrImageReaderSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  },
  "author": "shyam35 <shyam@getsprouter.com> (https://github.com/sprouter-llc-shyam)",
  "license": "UNLICENSED",
  "homepage": "https://github.com/sprouter-llc-shyam/sprouter-native-qr-image-reader",
  "files": [
    "src",
    "lib",
    "react-native.config.js",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "ios",
    "android",
    "*.podspec"
  ],
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "tools": [
      "eslint",
      "jest",
      "lefthook",
      "release-it"
    ],
    "version": "0.62.0"
  },
  "devDependencies": {
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-builder-bob": "^0.41.0",
    "release-it": "^20.0.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "typescript": "*"
  },
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "release": "release-it",
    "prepare": "bob build",
    "typescript": "tsc --noEmit",
    "rebuild": "rm -rf lib node_modules && npm install"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ]
}
