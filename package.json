{
  "name": "sprouter-native-qr-image-reader",
  "version": "1.0.0",
  "description": "sample",
  "main": "./lib/module/index.js",
  "codegenConfig": {
    "name": "SprouterNativeQrImageReaderSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  },
  "author": "shyam35 <shyam@getsprouter.com> (https://github.com/sprouter-llc-shyam)",
  "license": "UNLICENSED",
  "homepage": "https://github.com/sprouter-llc-shyam/sprouter-native-qr-image-reader#readme",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "ios",
    "android",
    "*.podspec"
  ],
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "tools": [
      "eslint",
      "jest",
      "lefthook",
      "release-it"
    ],
    "version": "0.62.0"
  },
  "devDependencies": {
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-builder-bob": "^0.41.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./lib/typescript/src/index.d.ts",
  "scripts": {
    "prepare": "bob build"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ]
}
